{
  "manifest_version": 3,
  "name": "WebPlayer",
  "version": "1.2.1",
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "webRequest",
    "scripting",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "player.html",
        "player.js",
        "libs/hls.min.js",
        "libs/dash.all.min.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
