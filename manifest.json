{
  "manifest_version": 3,
  "name": "WebPlayer",
  "version": "1.2.1",
  "description": "Intercepts video streams and launches them in a custom, feature-rich web player.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "webRequest",
    "scripting",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "player.html",
        "player.js",
        "libs/hls.min.js",
        "libs/dash.all.min.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
